# tools/fetch-live-pack.mjs — runtime config
#
# Copy to .env (local dev) or feed via your secret store / Kubernetes Secret
# in cluster.  Source with: `set -a; source .env; set +a; npm run fetch-live`.

# MCP server endpoint (JSON-RPC 2.0 over Streamable HTTP).
#
# Local dev (in-process MCP from krystalinex-core):
#   MCP_URL=http://localhost:3100
# In-cluster authenticated MCP (recommended for production refreshes):
#   MCP_URL=http://krystalinex-otel-mcp-server:3001
# In-cluster public MCP (no auth; restricted tool set, expect sparser pack):
#   MCP_URL=http://krystalinex-mcp-public:3001
MCP_URL=http://localhost:3100

# Bearer token for the authenticated MCP. Leave empty for the public/local MCP.
# In krystalinex-core's Helm chart this is `.Values.otelMcpServer.auth.agentKey`
# rendered into the `<release>-mcp-auth` Secret as `auth-keys.json`.
MCP_AUTH=

# Output path (relative to repo root).
OUTPUT=examples/production-live.pack.yaml

# Per-request MCP timeout in milliseconds (default 30000, capped at 300000).
# TOMOGRAPH_MCP_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Identity (docs/PRODUCTIZATION_PLAN.md Stage 1). Three postures:
#
#   LOCAL (default)     — nothing set below: loopback, no login, no friction.
#   STAND-ALONE USERS   — locally-defined users in a plain file. Create the
#                         first user and restart:
#                           npm run users -- add alice --name "Alice"
#                         The file existing arms the login page; the session
#                         secret auto-generates into <workspace>/session-secret.
#   OIDC                — SSO against any OIDC provider (wins over the users
#                         file). Requires the issuer + client id + a shared
#                         session secret.

# Stand-alone users file (default: <workspace>/users.json)
#TOMOGRAPH_USERS_FILE=.tomograph/users.json

# OIDC single sign-on
#TOMOGRAPH_OIDC_ISSUER=https://login.example.com/realms/main
#TOMOGRAPH_OIDC_CLIENT_ID=tomograph
#TOMOGRAPH_OIDC_CLIENT_SECRET=            # omit for a public PKCE client
#TOMOGRAPH_OIDC_REDIRECT_URL=https://tomograph.example.com/auth/callback
#TOMOGRAPH_SESSION_SECRET=                # >=32 chars; same on every instance
#TOMOGRAPH_SESSION_TTL_HOURS=8

# Tenancy (Stage 2 — workspace-per-org). No env var: tenancy arms when
# <workspace>/orgs.json exists (manage with `npm run orgs`). Requires
# identity (users file or OIDC); each org's state lives under
# <workspace>/orgs/<orgId>/; an existing flat workspace migrates to
# orgs/default/ on first boot. Clients pick the org with the
# X-Tomograph-Org header (default: the user's first membership).
#TOMOGRAPH_OIDC_ALLOW_HTTP=               # '1' only for local test IdPs

# Service-account / CI access (works alongside either identity posture)
#TOMOGRAPH_API_TOKEN=
#TOMOGRAPH_API_TOKEN_LABEL=ci-bot
