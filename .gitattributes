# Vendored upstream spec files MUST remain byte-identical to upstream so the
# sha256 checksums in vendor/observability-pack-spec/VERSIONS.json verify on
# every platform. Force LF regardless of core.autocrlf.
vendor/** text eol=lf

# Studio source files are LF too, by convention.
*.mjs   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
