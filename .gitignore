node_modules/
.DS_Store
*.log
.env
.env.*
# …but the documented example config must stay in the repo.
!.env.example

# Coverage output (c8 / nyc).
coverage/
.nyc_output/

# Local workspace — persisted packs, deploy audit, journey runs.
# Per-machine state, never source. TOMOGRAPH_WORKSPACE relocates it.
.tomograph/

# Pinned backend-validator binaries + compiled-artifact scratch
# (fetch-validators.mjs / test-backend-validate.mjs). Dev tooling,
# fetched on demand, never source.
.tools/

# Ad-hoc test/debug dumps created during fetcher + adapter probing.
# These are scratch artefacts, not source of truth.
.tmp-*
*.tmp.yaml
/diag.mjs

# Crawler drafts of real/private services. These are x-ray output from live
# repos and routinely carry real secrets (webhook tokens, on-call emails,
# internal URLs) — they must never land in this public repo.
*.service.repo.yaml
*.repo.pack.yaml

# Generated live MCP snapshots. The app may create these locally, but they are
# runtime evidence, not source fixtures.
/examples/production-live.pack.yaml
/examples/production-live.json

# Internal, repo-local working docs — status surveys, ad-hoc audits,
# brand/rename strategy and launch backlog. Not part of the public doc set.
# Archived locally under docs/archive/ (see docs/archive/README.md).
PROJECT_STATUS_SURVEY.md
docs/archive/TOMOGRAPH_BRAND_PLAN.md
docs/archive/TOMOGRAPH_MIGRATION_CHECKLIST.md

# Superseded scratch versions of the brand/architecture diagrams.
docs/diagrams/_prev*

# Generated provisioning files for the T2 provisioning-load test.
docker/.t2-provisioning/
