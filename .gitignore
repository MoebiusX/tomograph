node_modules/
.DS_Store
*.log
.env
.env.*

# Coverage output (c8 / nyc).
coverage/
.nyc_output/

# Ad-hoc test/debug dumps created during fetcher + adapter probing.
# These are scratch artefacts, not source of truth.
.tmp-*
*.tmp.yaml
/diag.mjs

# Crawler drafts of real/private services. These are x-ray output from live
# repos and routinely carry real secrets (webhook tokens, on-call emails,
# internal URLs) — they must never land in this public repo.
*.service.repo.yaml
*.repo.pack.yaml

# Generated live MCP snapshots. The app may create these locally, but they are
# runtime evidence, not source fixtures.
/examples/production-live.pack.yaml
/examples/production-live.json

# Internal, repo-local working docs — status surveys, ad-hoc audits,
# brand/rename strategy and launch backlog. Not part of the public doc set.
PROJECT_STATUS_SURVEY.md
docs/TOMOGRAPH_BRAND_PLAN.md
docs/TOMOGRAPH_MIGRATION_CHECKLIST.md
