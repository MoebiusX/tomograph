{
  "name": "tomograph",
  "version": "0.3.0",
  "description": "Tomograph — the Observability Compiler. Compiles, scans, and scores ObservabilityPack spec v1.2 manifests. Express server + thin client.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "packc": "tools/cli.mjs",
    "tomograph": "tools/cli.mjs"
  },
  "files": [
    "server/",
    "studio/",
    "tools/",
    "vendor/",
    "examples/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoebiusX/tomograph.git"
  },
  "bugs": {
    "url": "https://github.com/MoebiusX/tomograph/issues"
  },
  "homepage": "https://github.com/MoebiusX/tomograph#readme",
  "author": "Carlos Montero (https://github.com/MoebiusX)",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node server/index.mjs",
    "serve": "node server/index.mjs",
    "dev": "node server/index.mjs",
    "fetch-live": "node tools/fetch-live-pack.mjs",
    "drift": "node tools/detect-drift.mjs",
    "drift:profiles": "node tools/drift-profiles.mjs",
    "lint:drift": "node --check tools/detect-drift.mjs",
    "validate-pack": "node tools/validate-pack.mjs",
    "validate": "node tools/validate-pack.mjs vendor/observability-pack-spec/v1.2/examples/payment-service.pack.yaml",
    "lint:fetcher": "node --check tools/fetch-live-pack.mjs",
    "test:fetch": "node tools/test-fetch-live.mjs",
    "lint:adapter": "node --check tools/adapt-spec-pack.mjs && node --check tools/lib/adapter.mjs && node --check tools/lib/mini-yaml.mjs && node --check tools/lib/promql.mjs && node --check tools/lib/promql-lezer.mjs && node --check tools/lib/traceability.mjs && node --check tools/lib/traceability-graph.mjs",
    "lint:crawler": "node --check tools/crawl-repo.mjs && node --check tools/lib/crawler.mjs",
    "lint:server": "node --check server/index.mjs",
    "lint:studio": "node --check studio/app.mjs",
    "lint:cli": "node --check tools/cli.mjs",
    "lint:zip": "node --check tools/lib/zip.mjs",
    "adapt": "node tools/adapt-spec-pack.mjs",
    "crawl": "node tools/crawl-repo.mjs",
    "test:adapt": "node tools/test-adapt.mjs",
    "test:crawl": "node tools/test-crawl.mjs",
    "test:diff": "node tools/test-diff.mjs",
    "test:promql": "node tools/test-promql.mjs",
    "test:diagnostic": "node tools/test-diagnostic-grade.mjs",
    "test:traceability": "node tools/test-traceability-graph.mjs",
    "test:packs": "node tools/test-packs.mjs",
    "test:compile": "node tools/test-compile.mjs",
    "test:profiles": "node tools/test-profiles.mjs",
    "test:server": "node server/test-smoke.mjs",
    "test:zip": "node tools/test-zip.mjs",
    "test": "npm run test:adapt && npm run test:fetch && npm run test:packs && npm run test:compile && npm run test:profiles && npm run test:promql && npm run test:crawl && npm run test:diff && npm run test:diagnostic && npm run test:traceability && npm run test:zip && npm run test:server",
    "lint": "eslint .",
    "coverage": "c8 npm test",
    "sync-spec": "node tools/sync-spec.mjs",
    "sync-spec:check": "node tools/sync-spec.mjs --check"
  },
  "c8": {
    "reporter": ["text-summary", "lcov"],
    "include": ["server/**/*.mjs", "tools/**/*.mjs"],
    "exclude": ["tools/test-*.mjs", "tools/cli.mjs", "server/test-smoke.mjs"],
    "all": false
  },
  "dependencies": {
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@prometheus-io/lezer-promql": "^0.312.0-rc.0",
    "express": "^5.0.0"
  },
  "license": "MIT",
  "keywords": [
    "tomograph",
    "observability-compiler",
    "observability",
    "otel",
    "opentelemetry",
    "mcp",
    "sre",
    "slo",
    "prometheus",
    "grafana",
    "alertmanager",
    "spec",
    "v1.2"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0"
  }
}
