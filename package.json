{
  "name": "tomograph",
  "version": "1.0.0",
  "description": "Tomograph — the Observability Compiler. Compiles, scans, and scores ObservabilityPack spec v1.2 manifests. Express server + thin client.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "tomograph": "server/index.mjs"
  },
  "files": [
    "server/",
    "studio/",
    "tools/",
    "vendor/",
    "examples/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoebiusX/tomograph.git"
  },
  "bugs": {
    "url": "https://github.com/MoebiusX/tomograph/issues"
  },
  "homepage": "https://github.com/MoebiusX/tomograph#readme",
  "author": "Carlos Montero (https://github.com/MoebiusX)",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start":           "node server/index.mjs",
    "serve":           "node server/index.mjs",
    "dev":             "node server/index.mjs",
    "fetch-live":      "node tools/fetch-live-pack.mjs",
    "drift":           "node tools/detect-drift.mjs",
    "drift:profiles":  "node tools/drift-profiles.mjs",
    "lint:drift":      "node --check tools/detect-drift.mjs",
    "validate-pack":   "node tools/validate-pack.mjs",
    "validate":        "node tools/validate-pack.mjs vendor/observability-pack-spec/v1.2/examples/payment-service.pack.yaml",
    "lint:fetcher":    "node --check tools/fetch-live-pack.mjs",
    "test:fetch":      "node tools/test-fetch-live.mjs",
    "lint:adapter":    "node --check tools/adapt-spec-pack.mjs && node --check tools/lib/adapter.mjs && node --check tools/lib/mini-yaml.mjs",
    "lint:crawler":    "node --check tools/crawl-repo.mjs && node --check tools/lib/crawler.mjs",
    "lint:server":     "node --check server/index.mjs",
    "lint:studio":     "node --check studio/app.mjs",
    "adapt":           "node tools/adapt-spec-pack.mjs",
    "crawl":           "node tools/crawl-repo.mjs",
    "test:adapt":      "node tools/test-adapt.mjs",
    "test:crawl":      "node tools/test-crawl.mjs",
    "test:packs":      "node tools/test-packs.mjs",
    "test:compile":    "node tools/test-compile.mjs",
    "test:profiles":   "node tools/test-profiles.mjs",
    "test:server":     "node server/test-smoke.mjs",
    "sync-spec":       "node tools/sync-spec.mjs",
    "sync-spec:check": "node tools/sync-spec.mjs --check"
  },
  "dependencies": {
    "express": "^5.0.0"
  },
  "license": "MIT",
  "keywords": [
    "tomograph",
    "observability-compiler",
    "observability",
    "otel",
    "opentelemetry",
    "mcp",
    "sre",
    "slo",
    "prometheus",
    "grafana",
    "alertmanager",
    "spec",
    "v1.2"
  ]
}
